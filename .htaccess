  # .htaccess — luxinpro.es
# Incluye redirecciones 301 de páginas WordPress antiguas

Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ── 1. FORZAR HTTPS ────────────────────────────────────────────────
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # ── 2. FORZAR SIN WWW ──────────────────────────────────────────────
  RewriteCond %{HTTP_HOST} ^www\.luxinpro\.es$ [NC]
  RewriteRule ^ https://luxinpro.es%{REQUEST_URI} [R=301,L]

  # ── 3. REDIRECCIONES 301 — PÁGINAS WORDPRESS ANTIGUAS ──────────────
  # Páginas detectadas en Google indexadas del WordPress
  RewriteRule ^empresa/?$                          /                        [R=301,L]
  RewriteRule ^nosotros/?$                         /#nosotros               [R=301,L]
  RewriteRule ^sobre-nosotros/?$                   /#nosotros               [R=301,L]
  RewriteRule ^project-manager/?$                  /instalaciones.html      [R=301,L]
  RewriteRule ^building-manager/?$                 /instalaciones.html      [R=301,L]
  RewriteRule ^instalaciones-y-servicios/?$        /instalaciones.html      [R=301,L]
  RewriteRule ^servicios/?$                        /instalaciones.html      [R=301,L]
  RewriteRule ^archivos/?$                         /                        [R=301,L]
  RewriteRule ^archivos/propiedad/?$               /                        [R=301,L]
  RewriteRule ^busqueda-avanzada.*$                /                        [R=301,L]
  RewriteRule ^rocamar.*$                          /#menorca                [R=301,L]
  RewriteRule ^menorca/?$                          /#menorca                [R=301,L]
  RewriteRule ^contacto/?$                         /#contacto               [R=301,L]
  RewriteRule ^contact/?$                          /en/#contacto            [R=301,L]
  RewriteRule ^inicio/?$                           /                        [R=301,L]
  RewriteRule ^home/?$                             /                        [R=301,L]

  # Cualquier URL con ?p= o ?page_id= (WordPress) → inicio
  RewriteCond %{QUERY_STRING} (p|page_id|cat|tag|author|s|paged)=
  RewriteRule ^ /? [R=301,L]

  # Feed de WordPress → inicio
  RewriteRule ^feed/?$                             /                        [R=301,L]
  RewriteRule ^.*feed/?$                           /                        [R=301,L]

  # ── 4. DOCUMENTO INDEX ─────────────────────────────────────────────
  DirectoryIndex index.html

</IfModule>

# ── 5. HEADERS DE SEGURIDAD Y CACHÉ ───────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|css|js|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ── 6. COMPRESIÓN GZIP ────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
  AddOutputFilterByType DEFLATE image/svg+xml application/xml text/xml
</IfModule>

# ── 7. BLOQUEAR ARCHIVOS SENSIBLES ────────────────────────────────────
<FilesMatch "(wp-config\.php|xmlrpc\.php|readme\.html|license\.txt)$">
  Order allow,deny
  Deny from all
</FilesMatch>
